<Page x:Class="GithubManager.Views.FilesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:GithubManager"
      xmlns:vmv="clr-namespace:GithubManager.ViewModels"
      xmlns:c="clr-namespace:GithubManager.Converters"
      Background="{StaticResource BgBrush}">
    <Page.DataContext>
        <Binding Source="{x:Static vm:App.FilesVm}"/>
    </Page.DataContext>
    <Page.Resources>
        <c:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <c:NullToVisibilityConverter x:Key="NullToVis"/>
        <c:ErrorToColorConverter x:Key="ErrorToColor"/>
        <c:InverseBoolConverter x:Key="InverseBoolConv"/>
    </Page.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 仓库 / 分支选择 -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="选择仓库与分支" Foreground="{StaticResource MutedBrush}"/>
            <DockPanel>
                <Button Content="刷新" Command="{Binding RefreshReposCommand}" DockPanel.Dock="Right" Margin="4,0,0,0"/>
                <TextBox Text="{Binding RepoFilter, UpdateSourceTrigger=PropertyChanged}" Tag="搜索仓库..." Margin="0,0,4,0"/>
            </DockPanel>
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" ItemsSource="{Binding FilteredRepos}" SelectedItem="{Binding SelectedRepo, Mode=TwoWay}"
                          DisplayMemberPath="FullName" Background="#3C3C3C" Foreground="{StaticResource TextBrush}"
                          Margin="0,0,4,0" SelectionChanged="Repo_SelectionChanged"/>
                <Button Grid.Column="1" Content="加载分支" Command="{Binding LoadBranchesCommand}" Margin="0,0,4,0"/>
                <ComboBox Grid.Column="2" ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedBranch, Mode=TwoWay}"
                          DisplayMemberPath="Name" Background="#3C3C3C" Foreground="{StaticResource TextBrush}"
                          Margin="0,0,4,0"/>
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Content="删除仓库" Command="{Binding DeleteRepoCommand}"
                            Style="{StaticResource DangerButton}" Margin="0,0,4,0"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- 操作按钮 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="刷新" Command="{Binding OpenRepoCommand}"/>
            <TextBlock VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{StaticResource MutedBrush}"
                       Text="选中文件后："/>
            <Button Content="下载" Click="Download_Click"/>
            <Button Content="编辑" Click="Edit_Click"/>
            <Button Content="删除" Click="Delete_Click"/>
            <TextBlock VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{StaticResource MutedBrush}"
                       Text="双击文件夹展开/收起"/>
        </StackPanel>

        <!-- 文件树 -->
        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" CornerRadius="6" Margin="0,8" Padding="8">
            <TreeView ItemsSource="{Binding RootItems}"
                      Background="Transparent" BorderThickness="0"
                      MouseDoubleClick="TreeView_DoubleClick"
                      SelectedItemChanged="TreeView_SelectedItemChanged">
                <TreeView.Resources>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="2,1"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TreeViewItem">
                                    <StackPanel>
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter x:Name="PART_Header"
                                                              ContentSource="Header"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                        </Border>
                                        <ItemsPresenter x:Name="ItemsHost" Margin="16,0,0,0"/>
                                    </StackPanel>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsExpanded" Value="False">
                                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#3C5A6E"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsSelected" Value="True"/>
                                                <Condition Property="IsSelectionActive" Value="True"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="Bd" Property="Background" Value="#3C5A6E"/>
                                        </MultiTrigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsSelected" Value="True"/>
                                                <Condition Property="IsSelectionActive" Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TreeView.Resources>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate DataType="{x:Type vmv:ContentTreeItem}"
                                              ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Height="22">
                            <TextBlock Text="{Binding Icon}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="{Binding SizeText}" VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedBrush}" Margin="16,0,0,0"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>

        <!-- 状态提示 -->
        <Border Grid.Row="3" Style="{StaticResource StatusBanner}"
                Background="{Binding IsError, Converter={StaticResource ErrorToColor}}">
            <DockPanel>
                <TextBlock Text="{Binding StatusMessage}" Foreground="White" TextWrapping="Wrap"
                           DockPanel.Dock="Left" VerticalAlignment="Center"/>
                <Button Content="详情" DockPanel.Dock="Right" Click="ShowTechDetail_Click"
                        Visibility="{Binding TechnicalDetail, Converter={StaticResource BoolToVis}}"
                        Background="#33000000" Foreground="White" Padding="8,2"/>
            </DockPanel>
        </Border>
        <TextBox Grid.Row="3" Text="{Binding TechnicalDetail}" IsReadOnly="True" Visibility="Collapsed"
                 x:Name="TechDetailBox" Background="#1A1A1A" Foreground="{StaticResource MutedBrush}"
                 TextWrapping="Wrap" MaxHeight="200" Margin="4"/>
    </Grid>
</Page>
