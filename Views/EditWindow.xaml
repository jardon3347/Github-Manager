<Window x:Class="GithubManager.Views.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:GithubManager.Converters"
        Title="编辑文件" Height="600" Width="900"
        Background="{StaticResource BgBrush}" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <c:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <c:ErrorToColorConverter x:Key="ErrorToColor"/>
        <c:InverseBoolConverter x:Key="InverseBoolConv"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Foreground="{StaticResource MutedBrush}">
            <Run Text="编辑："/>
            <Run Text="{Binding Path, Mode=OneWay}" FontWeight="SemiBold"/>
        </TextBlock>

        <TextBox Grid.Row="1" Text="{Binding EditContent, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="13"
                 Background="#1A1A1A" Foreground="{StaticResource TextBrush}" BorderBrush="#555"/>

        <TextBox Grid.Row="2" Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                 Tag="commit message（必填）" Margin="0,8,0,0"/>

        <Border Grid.Row="3" Style="{StaticResource StatusBanner}"
                Background="{Binding IsError, Converter={StaticResource ErrorToColor}}" Margin="0,8,0,0">
            <DockPanel>
                <TextBlock Text="{Binding StatusMessage}" Foreground="White" TextWrapping="Wrap"
                           DockPanel.Dock="Left" VerticalAlignment="Center"/>
                <Button Content="详情" DockPanel.Dock="Right" Click="ShowTechDetail_Click"
                        Visibility="{Binding TechnicalDetail, Converter={StaticResource BoolToVis}}"
                        Background="#33000000" Foreground="White" Padding="8,2"/>
            </DockPanel>
        </Border>
        <TextBox Grid.Row="3" Text="{Binding TechnicalDetail}" IsReadOnly="True" Visibility="Collapsed"
                 x:Name="TechDetailBox" Background="#1A1A1A" Foreground="{StaticResource MutedBrush}"
                 TextWrapping="Wrap" MaxHeight="120" Margin="4"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="提交" Click="Submit_Click" FontWeight="Bold" IsDefault="True"/>
            <Button Content="取消" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
