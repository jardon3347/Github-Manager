<Page x:Class="GithubManager.Views.ReleasePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:GithubManager"
      xmlns:c="clr-namespace:GithubManager.Converters"
      Background="{StaticResource BgBrush}">
    <Page.DataContext>
        <Binding Source="{x:Static vm:App.ReleaseVm}"/>
    </Page.DataContext>
    <Page.Resources>
        <c:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <c:NullToVisibilityConverter x:Key="NullToVis"/>
        <c:ErrorToColorConverter x:Key="ErrorToColor"/>
        <c:InverseBoolConverter x:Key="InverseBoolConv"/>
    </Page.Resources>
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左：Release 信息 -->
        <StackPanel Grid.Column="0" Margin="0,0,16,0">
            <TextBlock Text="发布 Release" Style="{StaticResource SectionHeader}"/>

            <TextBlock Text="仓库" Foreground="{StaticResource MutedBrush}"/>
            <DockPanel>
                <Button Content="刷新" Command="{Binding RefreshReposCommand}" DockPanel.Dock="Right" Margin="4,0,0,0"/>
                <TextBox Text="{Binding RepoFilter, UpdateSourceTrigger=PropertyChanged}" Tag="搜索仓库..."/>
            </DockPanel>
            <ComboBox ItemsSource="{Binding FilteredRepos}" SelectedItem="{Binding SelectedRepo, Mode=TwoWay}"
                      DisplayMemberPath="FullName" Background="#3C3C3C" Foreground="{StaticResource TextBrush}"
                      Margin="0,4" SelectionChanged="Repo_SelectionChanged"/>

            <DockPanel Margin="0,4">
                <TextBlock Text="分支：" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                <Button Content="加载分支" Command="{Binding LoadBranchesCommand}" DockPanel.Dock="Right" Margin="4,0,0,0"/>
                <ComboBox ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedBranch, Mode=TwoWay}"
                          DisplayMemberPath="Name" Background="#3C3C3C" Foreground="{StaticResource TextBrush}"/>
            </DockPanel>

            <TextBlock Text="Tag（必填）" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"/>
            <TextBox Text="{Binding TagName, UpdateSourceTrigger=PropertyChanged}" Tag="如 v1.0.0"/>

            <TextBlock Text="标题（必填）" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"/>
            <TextBox Text="{Binding ReleaseTitle, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="正文（Markdown）" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"/>
            <TextBox Text="{Binding ReleaseBody, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True"
                     TextWrapping="Wrap" Height="160" VerticalScrollBarVisibility="Auto"/>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <CheckBox Content="Draft（草稿）" IsChecked="{Binding IsDraft}" Foreground="{StaticResource TextBrush}" Margin="2"/>
                <CheckBox Content="Prerelease（预发布）" IsChecked="{Binding IsPrerelease}" Foreground="{StaticResource TextBrush}" Margin="16,2,2,2"/>
            </StackPanel>

            <Button Content="创建 Release" Command="{Binding CreateReleaseCommand}" HorizontalAlignment="Left"
                    Margin="0,12,0,0" FontWeight="Bold" FontSize="14"/>
        </StackPanel>

        <!-- 右：资产 -->
        <StackPanel Grid.Column="1" Margin="16,0,0,0">
            <DockPanel>
                <TextBlock Text="资产（二进制文件）" Style="{StaticResource SectionHeader}" DockPanel.Dock="Left"/>
                <Button Content="添加文件" Command="{Binding AddAssetsCommand}" DockPanel.Dock="Right" Margin="4,0,0,0"/>
            </DockPanel>
            <Border Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="8" MinHeight="200">
                <DataGrid ItemsSource="{Binding Assets}" AutoGenerateColumns="False"
                          Background="Transparent" Foreground="{StaticResource TextBrush}"
                          RowBackground="#2A2A2A" AlternatingRowBackground="#252525"
                          GridLinesVisibility="Horizontal" BorderThickness="0"
                          HeadersVisibility="Column" CanUserAddRows="False">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#333"/>
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            <Setter Property="Padding" Value="6,4"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="选" Binding="{Binding Selected, Mode=TwoWay}" Width="40"/>
                        <DataGridTextColumn Header="文件名" Binding="{Binding FileName}" Width="*"/>
                        <DataGridTextColumn Header="大小" Binding="{Binding SizeText}" Width="80"/>
                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="120"/>
                        <DataGridTemplateColumn Header="" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="移除" Command="{Binding DataContext.RemoveAssetCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}" Padding="6,2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <ProgressBar Value="{Binding ProgressValue}" Height="16" Minimum="0" Maximum="100" Margin="0,8"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

            <Border Style="{StaticResource StatusBanner}"
                    Background="{Binding IsError, Converter={StaticResource ErrorToColor}}">
                <DockPanel>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="White" TextWrapping="Wrap"
                               DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <Button Content="详情" DockPanel.Dock="Right" Click="ShowTechDetail_Click"
                            Visibility="{Binding TechnicalDetail, Converter={StaticResource BoolToVis}}"
                            Background="#33000000" Foreground="White" Padding="8,2"/>
                </DockPanel>
            </Border>
            <TextBox Text="{Binding TechnicalDetail}" IsReadOnly="True" Visibility="Collapsed"
                     x:Name="TechDetailBox" Background="#1A1A1A" Foreground="{StaticResource MutedBrush}"
                     TextWrapping="Wrap" MaxHeight="200" Margin="4"/>
        </StackPanel>
    </Grid>
</Page>
