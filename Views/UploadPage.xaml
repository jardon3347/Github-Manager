<Page x:Class="GithubManager.Views.UploadPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:GithubManager"
      xmlns:vmv="clr-namespace:GithubManager.ViewModels"
      xmlns:c="clr-namespace:GithubManager.Converters"
      Background="{StaticResource BgBrush}">
    <Page.DataContext>
        <Binding Source="{x:Static vm:App.UploadVm}"/>
    </Page.DataContext>
    <Page.Resources>
        <c:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <c:NullToVisibilityConverter x:Key="NullToVis"/>
        <c:ErrorToColorConverter x:Key="ErrorToColor"/>
        <c:InverseBoolConverter x:Key="InverseBoolConv"/>
    </Page.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 仓库选择 + 新建 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="选择仓库" Foreground="{StaticResource MutedBrush}"/>
                <DockPanel>
                    <Button Content="刷新" Command="{Binding RefreshReposCommand}" DockPanel.Dock="Right" Margin="4,0,0,0"/>
                    <TextBox Text="{Binding RepoFilter, UpdateSourceTrigger=PropertyChanged}" Tag="搜索仓库..."/>
                </DockPanel>
                <ComboBox ItemsSource="{Binding FilteredRepos}" SelectedItem="{Binding SelectedRepo, Mode=TwoWay}"
                          DisplayMemberPath="FullName" Margin="0,4" Background="#3C3C3C" Foreground="{StaticResource TextBrush}"
                          SelectionChanged="Repo_SelectionChanged"/>
                <DockPanel Margin="0,4">
                    <TextBlock Text="分支：" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                    <Button Content="加载分支" Command="{Binding LoadBranchesCommand}" DockPanel.Dock="Right" Margin="4,0,0,0"/>
                    <ComboBox ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedBranch, Mode=TwoWay}"
                              DisplayMemberPath="Name" Background="#3C3C3C" Foreground="{StaticResource TextBrush}"/>
                </DockPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="16,0,0,0" Width="240">
                <TextBlock Text="或新建仓库" Foreground="{StaticResource MutedBrush}"/>
                <TextBox Text="{Binding NewRepoName, UpdateSourceTrigger=PropertyChanged}" Tag="仓库名"/>
                <TextBox Text="{Binding NewRepoDescription, UpdateSourceTrigger=PropertyChanged}" Tag="描述"/>
                <CheckBox Content="私有" IsChecked="{Binding NewRepoPrivate}" Foreground="{StaticResource TextBrush}" Margin="2"/>
                <CheckBox Content="自动创建 README" IsChecked="{Binding NewRepoAutoInit}" Foreground="{StaticResource TextBrush}" Margin="2"/>
                <Button Content="新建" Command="{Binding CreateRepoCommand}"/>
            </StackPanel>
        </Grid>

        <!-- 本地文件夹 -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="选择文件夹" Command="{Binding PickFolderCommand}"/>
            <TextBox Grid.Column="1" Text="{Binding LocalFolder}" IsReadOnly="True" Margin="8,2"/>
            <Button Grid.Column="2" Content="刷新" Width="48" ToolTip="刷新文件夹内容"
                    Command="{Binding RefreshFolderCommand}" Margin="2,0" Padding="8,4"/>
            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <TextBox Text="{Binding TargetPath, UpdateSourceTrigger=PropertyChanged}" Width="160"
                         ToolTip="仓库内目标路径（如 docs/2026/），空即根目录" Tag="目标路径"/>
                <TextBox Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}" Width="200"
                         ToolTip="commit message" Tag="commit message"/>
                <Button Content="上传" Command="{Binding UploadCommand}" FontWeight="Bold"/>
            </StackPanel>
        </Grid>

        <!-- 文件列表 -->
        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" CornerRadius="6" Margin="0,8" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 工具栏 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="全选 / 取消全选" Command="{Binding ToggleAllCommand}"
                            Padding="8,4" FontSize="11"/>
                    <TextBlock VerticalAlignment="Center" Margin="16,0,0,0"
                               Foreground="{StaticResource MutedBrush}"
                               Text="双击文件夹展开/收起"/>
                </StackPanel>

                <!-- TreeView -->
                <TreeView Grid.Row="1" ItemsSource="{Binding RootItems}"
                          Background="Transparent" BorderThickness="0"
                          MouseDoubleClick="TreeView_DoubleClick">
                    <TreeView.Resources>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="2,1"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TreeViewItem">
                                        <StackPanel>
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter x:Name="PART_Header" ContentSource="Header"
                                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                            </Border>
                                            <ItemsPresenter x:Name="ItemsHost" Margin="16,0,0,0"/>
                                        </StackPanel>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsExpanded" Value="False">
                                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#3C5A6E"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TreeView.Resources>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type vmv:UploadTreeItem}"
                                                  ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Height="22">
                                <CheckBox IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}"
                                          Click="TreeCheckBox_Click" VerticalAlignment="Center"
                                          Foreground="{StaticResource TextBrush}" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding Icon}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="{Binding SizeText}" VerticalAlignment="Center"
                                           Foreground="{StaticResource MutedBrush}" Margin="16,0,0,0"/>
                                <TextBlock Text="{Binding Status}" VerticalAlignment="Center"
                                           Foreground="{StaticResource OkBrush}" Margin="16,0,0,0"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>
        </Border>

        <!-- 进度 + 状态 -->
        <StackPanel Grid.Row="3">
            <ProgressBar Value="{Binding ProgressValue}" Height="16" Minimum="0" Maximum="100"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            <Border Style="{StaticResource StatusBanner}"
                    Background="{Binding IsError, Converter={StaticResource ErrorToColor}}">
                <DockPanel>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="White" TextWrapping="Wrap"
                               DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <Button Content="详情" DockPanel.Dock="Right" Click="ShowTechDetail_Click"
                            Visibility="{Binding TechnicalDetail, Converter={StaticResource BoolToVis}}"
                            Background="#33000000" Foreground="White" Padding="8,2"/>
                </DockPanel>
            </Border>
            <TextBox Text="{Binding TechnicalDetail}" IsReadOnly="True" Visibility="Collapsed"
                     x:Name="TechDetailBox" Background="#1A1A1A" Foreground="{StaticResource MutedBrush}"
                     TextWrapping="Wrap" MaxHeight="200" Margin="4"/>
        </StackPanel>
    </Grid>
</Page>
